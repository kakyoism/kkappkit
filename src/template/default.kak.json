{
  "format": "1",
  "backend": {
    "root": "</path/to/backend_root with a pyproject.toml>",
    "service": {
      "my_service": "src/cli.py",
      "my_command": "/path/to/my.kakcmd.json"
    }
  },
  "server": {
    "protocol": "grpc",
    "ip": "127.0.0.1",
    "port": "*",
    "api": "/path/to/api/"
  },
  "ui": {
    "layout": "/path/to/my_app.kaklayout.json",
    "theme": "/path/to/my_app.kaktheme.json",
    "behaviour": "/path/to/my_app.kakbehav.json",
    "binding": "/path/to/my_app.kakbind.json"
  }
}