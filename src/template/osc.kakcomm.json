{
  "_version": 1,
  "protocol": "osc",
  "shoot_and_forget": {
    "sender": "${kakbind}.key1",
    "topic": "/push"
  },
  "bidirectional": {
    "sender": "${kakbind}.key2",
    "topic": "/question",
    "response": "/answer"
  },
  "parameterized": {
    "sender": "${kakbind}.key3",
    "topic": "/function",
    "payload": {
      "arg1": "${kakbind}.key3",
      "arg2": "${kakbind}.key4"
    }
  }
}