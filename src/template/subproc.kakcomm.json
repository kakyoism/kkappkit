{
  "_version": 1,
  "protocol": "subprocess",
  "submit": {
    "sender": "kak.frontend.control.action.submit",
    "request": ["poetry", "run", "python", "%(cli)s"],
    "payload": {
      "--auto-save-preset": "kak.frontend.binding.auto_save_preset",
      "--session-id": "kak.name"
    },
    "env": {
      "PYTHONPATH": "."
    },
    "cwd": "."
  }
}